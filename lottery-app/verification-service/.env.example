SECRET_KEY=dev-secret-verification
AWS_REGION=us-east-1
DB_SECRET_NAME=lottery/rds/credentials
CLAIMS_SERVICE_URL=http://localhost:8001
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/lottery-platform-verification-claims-queue
# Leave REDIS_URL empty to run without caching (e.g., local dev).
# In production this is set to the ElastiCache primary endpoint via Terraform.
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600